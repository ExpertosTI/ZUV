---
import { getInvoice } from '../../lib/store';

export const prerender = false;

const id = Astro.params.id || '';
const invoice = id ? await getInvoice(id) : null;

if (!invoice) {
  return new Response('Invoice not found', { status: 404 });
}

const b = invoice.billingSnapshot;
const money = (n: number) =>
  new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: invoice.currency || 'USD',
  }).format(n);

const freqLabel =
  invoice.frequency === 'weekly'
    ? 'Weekly'
    : invoice.frequency === 'biweekly'
      ? 'Every 2 weeks'
      : invoice.frequency === 'monthly'
        ? 'Monthly'
        : 'One-time';

const periodStart = new Date(invoice.periodStart).toLocaleDateString();
const periodEnd = new Date(invoice.periodEnd).toLocaleDateString();
const nextAt = invoice.nextInvoiceAt
  ? new Date(invoice.nextInvoiceAt).toLocaleDateString()
  : null;

// Prefer same-origin asset so print/PDF always resolves the transparent logo
const logoUrl = '/logo.png';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice {invoice.number} · ZAV</title>
    <style>
      body { font-family: DM Sans, system-ui, sans-serif; margin: 0; background: #f7f4ef; color: #1a1a1a; }
      .sheet { max-width: 760px; margin: 24px auto; background: #fff; border-radius: 16px; padding: 32px; box-shadow: 0 10px 40px rgba(0,0,0,.08); }
      .top { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; border-bottom: 2px solid #c9a227; padding-bottom: 16px; }
      .brand { display: flex; flex-direction: column; gap: 8px; }
      .brand img { display: block; width: min(240px, 100%); height: auto; background: transparent; }
      h1 { margin: 0; font-size: 22px; }
      .muted { color: #6b6560; font-size: 13px; }
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 24px 0; }
      table { width: 100%; border-collapse: collapse; margin-top: 12px; }
      th, td { text-align: left; padding: 10px 8px; border-bottom: 1px solid #efe8dc; }
      .totals { margin-top: 16px; margin-left: auto; width: 240px; }
      .totals div { display: flex; justify-content: space-between; padding: 6px 0; }
      .totals .grand { font-weight: 800; font-size: 18px; border-top: 2px solid #1b3a5c; margin-top: 8px; padding-top: 10px; }
      .actions { margin: 16px auto; max-width: 760px; display: flex; gap: 8px; }
      .actions button, .actions a { border: 0; border-radius: 999px; padding: 10px 16px; background: #1b3a5c; color: #fff; text-decoration: none; font-weight: 600; cursor: pointer; }
      .pill { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 4px 10px; font-size: 11px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; background: #f3e7c0; color: #7a5d10; }
      .pill-recurring { background: #d1fae5; color: #065f46; }
      .meta-box { margin-top: 18px; padding: 12px 14px; border-radius: 12px; background: #faf7f1; border: 1px solid #efe8dc; }
      @media print { .actions { display: none; } body { background: #fff; } .sheet { box-shadow: none; margin: 0; } }
      @media (max-width: 640px) { .grid, .top { grid-template-columns: 1fr; display: grid; } }
    </style>
  </head>
  <body>
    <div class="actions">
      <button type="button" onclick="window.print()">Print / PDF</button>
      <a href="/">Back to site</a>
    </div>
    <article class="sheet">
      <div class="top">
        <div class="brand">
          <img src={logoUrl} alt="ZAV Interior & Clean" width="240" height="126" />
          <p class="muted" style="margin:0">{b.legalName || b.businessName}</p>
          <p class="muted" style="margin:0">{b.address}{b.city ? ` · ${b.city}` : ''}</p>
          <p class="muted" style="margin:0">{b.email} · {b.phone}</p>
          {b.taxId && <p class="muted" style="margin:0">Tax ID: {b.taxId}</p>}
        </div>
        <div style="text-align:right">
          <p style="margin:0;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#a8841a;font-weight:700">Invoice</p>
          <p style="margin:6px 0 0;font-size:22px;font-weight:800">{invoice.number}</p>
          <p class="muted">{new Date(invoice.createdAt).toLocaleDateString()}</p>
          <p class="muted">Status: {invoice.status}</p>
          {invoice.recurring ? (
            <p style="margin-top:8px"><span class="pill pill-recurring">Recurring · {freqLabel}</span></p>
          ) : (
            <p style="margin-top:8px"><span class="pill">One-time</span></p>
          )}
        </div>
      </div>

      <div class="grid">
        <div>
          <p style="margin:0 0 6px;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#a8841a;font-weight:700">Bill to</p>
          <p style="margin:0;font-weight:700">{invoice.clientName}</p>
          <p class="muted">{invoice.clientEmail}</p>
          <p class="muted">{invoice.clientPhone}</p>
          <p class="muted">{invoice.clientAddress}</p>
        </div>
        <div>
          <p style="margin:0 0 6px;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#a8841a;font-weight:700">Service</p>
          <p style="margin:0;font-weight:700">{invoice.service}</p>
          <p class="muted">Quote: {invoice.quoteId}</p>
          {invoice.recurring && (
            <p class="muted">Cycle #{invoice.cycle} · Series {invoice.seriesId.slice(0, 18)}…</p>
          )}
        </div>
      </div>

      {invoice.recurring && (
        <div class="meta-box">
          <strong>Billing period:</strong> {periodStart} — {periodEnd}
          {nextAt && (
            <span class="muted"> · Next invoice: {nextAt}</span>
          )}
        </div>
      )}

      <table>
        <thead>
          <tr><th>Description</th><th style="text-align:right">Amount</th></tr>
        </thead>
        <tbody>
          <tr>
            <td>
              {invoice.description}
              {invoice.recurring && (
                <div class="muted">Recurring service · {freqLabel} · period {periodStart} to {periodEnd}</div>
              )}
            </td>
            <td style="text-align:right">{money(invoice.amount)}</td>
          </tr>
        </tbody>
      </table>

      <div class="totals">
        <div><span>Subtotal</span><span>{money(invoice.amount)}</span></div>
        <div><span>Tax</span><span>{money(invoice.tax)}</span></div>
        <div class="grand"><span>Total</span><span>{money(invoice.total)}</span></div>
      </div>

      {invoice.notes && <p class="muted" style="margin-top:28px">{invoice.notes}</p>}
    </article>
  </body>
</html>
