---
import type { Messages } from '../i18n/messages';
import { EMAIL, INSTAGRAM, PHONE_DISPLAY, PHONE_E164, whatsappUrl } from '../lib/contact';
import BrandLogo from './BrandLogo.astro';

interface Props {
  m: Messages;
}

const { m } = Astro.props;
const year = new Date().getFullYear();
const wa = whatsappUrl(m.whatsappMsg);
---

<footer class="section-block border-t border-black/5 px-4 py-14 sm:px-6">
  <div class="mx-auto grid max-w-6xl gap-10 sm:grid-cols-[1.2fr_1fr]">
    <div class="reveal">
      <BrandLogo size="lg" class="max-w-[280px] sm:max-w-[320px]" />
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-muted">{m.tagline}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-wa !px-4 !py-2.5 text-xs">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.5 0 .2 5.3.2 11.82c0 2.08.54 4.1 1.58 5.9L0 24l6.45-1.69a11.8 11.8 0 0 0 5.59 1.42h.01c6.54 0 11.84-5.3 11.84-11.82 0-3.16-1.23-6.13-3.37-8.43ZM12.05 21.5h-.01a9.8 9.8 0 0 1-5-1.37l-.36-.21-3.83 1 1.02-3.73-.23-.38a9.8 9.8 0 0 1-1.5-5.23c0-5.42 4.42-9.83 9.86-9.83a9.8 9.8 0 0 1 6.97 2.89 9.76 9.76 0 0 1 2.88 6.95c0 5.42-4.42 9.84-9.8 9.84Z" />
          </svg>
          {m.whatsappCta}
        </a>
        <a href="#quote" class="btn-accent !px-4 !py-2.5 text-xs">{m.navQuote}</a>
      </div>
    </div>

    <div class="reveal reveal-delay-1 space-y-3">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-mustard-deep">{m.contactTitle}</p>
      <a href={`tel:${PHONE_E164}`} class="contact-row interactive">
        <span class="contact-icon">☎</span>
        {PHONE_DISPLAY}
      </a>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="contact-row interactive">
        <span class="contact-icon contact-icon--wa">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.5 0 .2 5.3.2 11.82c0 2.08.54 4.1 1.58 5.9L0 24l6.45-1.69a11.8 11.8 0 0 0 5.59 1.42h.01c6.54 0 11.84-5.3 11.84-11.82 0-3.16-1.23-6.13-3.37-8.43ZM12.05 21.5h-.01a9.8 9.8 0 0 1-5-1.37l-.36-.21-3.83 1 1.02-3.73-.23-.38a9.8 9.8 0 0 1-1.5-5.23c0-5.42 4.42-9.83 9.86-9.83a9.8 9.8 0 0 1 6.97 2.89 9.76 9.76 0 0 1 2.88 6.95c0 5.42-4.42 9.84-9.8 9.84Z" />
          </svg>
        </span>
        {m.whatsapp}
      </a>
      <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="contact-row interactive">
        <span class="contact-icon">◎</span>
        {m.contactIg}
      </a>
      <a href={`mailto:${EMAIL}`} class="contact-row interactive">
        <span class="contact-icon">✉</span>
        {m.contactEmail}
      </a>
    </div>
  </div>

  <div class="mx-auto mt-10 flex max-w-6xl flex-col gap-2 border-t border-black/5 pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {m.brand}. {m.footerRights}</p>
  </div>
</footer>
