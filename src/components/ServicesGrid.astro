---
import type { Messages } from '../i18n/messages';

interface Props {
  m: Messages;
}

const { m } = Astro.props;

const items = [
  { key: 'home', href: '#quote', img: '/service-home.jpg', label: m.services.home },
  { key: 'office', href: '#quote', img: '/service-office.jpg', label: m.servicesOffice },
  { key: 'move', href: '#quote', img: '/service-move.jpg', label: m.services.move },
  { key: 'deep', href: '#quote', img: '/service-deep.jpg', label: m.services.deep },
] as const;
---

<section id="services" class="px-4 py-14 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-10 max-w-2xl">
      <h2 class="font-display text-3xl tracking-tight text-ink sm:text-4xl">{m.servicesTitle}</h2>
      <p class="mt-3 text-muted">{m.servicesSub}</p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item, i) => (
        <a
          href={item.href}
          class:list={['service-tile reveal interactive', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2', i === 3 && 'reveal-delay-3']}
        >
          <div class="service-tile__media">
            <img src={item.img} alt="" width="480" height="600" loading="lazy" decoding="async" sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 240px" />
          </div>
          <span class="service-tile__label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .service-tile {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .service-tile__media {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 5;
    background: var(--color-cream-dark);
  }
  .service-tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (hover: none), (pointer: coarse) {
    .service-tile__media img {
      transition: none;
    }
    .service-tile:hover .service-tile__media img {
      transform: none;
    }
  }
  .service-tile:hover .service-tile__media img {
    transform: scale(1.04);
  }
  .service-tile__label {
    display: block;
    margin-top: 0.85rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--color-ink);
  }
</style>
