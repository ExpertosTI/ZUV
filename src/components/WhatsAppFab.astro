---
import type { Messages } from '../i18n/messages';
import { whatsappUrl } from '../lib/contact';

interface Props {
  m: Messages;
}

const { m } = Astro.props;
const href = whatsappUrl(m.whatsappMsg);
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-fab magnet interactive"
  aria-label={m.whatsappCta}
>
  <span class="magnet__inner flex items-center gap-2">
    <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.5 0 .2 5.3.2 11.82c0 2.08.54 4.1 1.58 5.9L0 24l6.45-1.69a11.8 11.8 0 0 0 5.59 1.42h.01c6.54 0 11.84-5.3 11.84-11.82 0-3.16-1.23-6.13-3.37-8.43ZM12.05 21.5h-.01a9.8 9.8 0 0 1-5-1.37l-.36-.21-3.83 1 1.02-3.73-.23-.38a9.8 9.8 0 0 1-1.5-5.23c0-5.42 4.42-9.83 9.86-9.83a9.8 9.8 0 0 1 6.97 2.89 9.76 9.76 0 0 1 2.88 6.95c0 5.42-4.42 9.84-9.8 9.84Zm5.4-7.37c-.3-.15-1.75-.86-2.02-.96-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.3-.02-.46.13-.6.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.08 1.75-.72 2-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35Z" />
    </svg>
    <span class="wa-fab__label hidden sm:inline">{m.whatsapp}</span>
  </span>
</a>
