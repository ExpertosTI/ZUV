---
import type { Locale, Messages } from '../i18n/messages';
import { LOCALES, localeLabels } from '../i18n/messages';
import { whatsappUrl } from '../lib/contact';

interface Props {
  locale: Locale;
  m: Messages;
}

const { locale, m } = Astro.props;
const wa = whatsappUrl(m.whatsappMsg);

const links = [
  { href: '#services', label: m.navServices, id: 'services' },
  { href: '#work', label: m.navWork, id: 'work' },
  { href: '#quote', label: m.navQuote, id: 'quote' },
];
---

<header id="site-header" class="site-header sticky top-0 z-50">
  <div class="header-progress" id="scroll-progress" aria-hidden="true"></div>

  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 sm:py-4">
    <a href="#top" class="brand-link interactive flex min-w-0 items-center gap-2.5 sm:gap-3" aria-label={m.brand}>
      <img
        src="/header-brand.jpg"
        alt=""
        width="80"
        height="80"
        class="header-brand-photo h-11 w-11 rounded-full object-cover sm:h-12 sm:w-12"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <span class="header-brand-text min-w-0">
        <span class="font-display block text-[1.05rem] leading-none text-ink sm:text-lg">ZAV</span>
        <span class="mt-0.5 block text-[9px] font-semibold uppercase tracking-[0.16em] text-muted sm:text-[10px]">Interior & Clean</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          class="nav-link interactive"
          data-nav={link.id}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-2.5">
      <div
        class="flex items-center rounded-full border border-black/8 bg-white/80 p-0.5 shadow-sm"
        role="group"
        aria-label={m.langLabel}
      >
        {LOCALES.map((code) => (
          <button
            type="button"
            class:list={[
              'lang-btn rounded-full px-2.5 py-1 text-[11px] font-semibold tracking-wide transition-all duration-300',
              code === locale
                ? 'bg-navy text-white shadow-sm'
                : 'text-muted hover:text-ink',
            ]}
            data-locale={code}
            aria-pressed={code === locale}
          >
            {localeLabels[code]}
          </button>
        ))}
      </div>

      <a
        href={wa}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-wa interactive hidden !px-3 !py-2 text-xs sm:inline-flex"
        aria-label={m.whatsappCta}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.5 0 .2 5.3.2 11.82c0 2.08.54 4.1 1.58 5.9L0 24l6.45-1.69a11.8 11.8 0 0 0 5.59 1.42h.01c6.54 0 11.84-5.3 11.84-11.82 0-3.16-1.23-6.13-3.37-8.43ZM12.05 21.5h-.01a9.8 9.8 0 0 1-5-1.37l-.36-.21-3.83 1 1.02-3.73-.23-.38a9.8 9.8 0 0 1-1.5-5.23c0-5.42 4.42-9.83 9.86-9.83a9.8 9.8 0 0 1 6.97 2.89 9.76 9.76 0 0 1 2.88 6.95c0 5.42-4.42 9.84-9.8 9.84Z" />
        </svg>
        <span class="hidden md:inline">{m.whatsapp}</span>
      </a>

      <a href="#quote" class="magnet btn-accent hidden !px-4 !py-2.5 text-xs sm:inline-flex">
        <span class="magnet__inner">{m.navQuote}</span>
      </a>

      <button
        type="button"
        id="nav-toggle"
        class="interactive flex h-10 w-10 items-center justify-center rounded-full border border-black/8 bg-white/80 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label={m.navMenu}
      >
        <span class="nav-toggle-icon" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav lg:hidden" hidden>
    <nav class="mx-auto flex max-w-6xl flex-col gap-1 px-4 pb-4 sm:px-6" aria-label="Mobile">
      {links.map((link) => (
        <a href={link.href} class="mobile-nav-link interactive" data-nav={link.id}>
          {link.label}
        </a>
      ))}
      <div class="mt-2 grid grid-cols-2 gap-2">
        <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-wa justify-center !py-3 text-sm">
          {m.whatsapp}
        </a>
        <a href="#quote" class="btn-accent justify-center !py-3 text-sm">
          {m.navQuote}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const progress = document.getElementById('scroll-progress');
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const navLinks = [...document.querySelectorAll('[data-nav]')];

  document.querySelectorAll('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const locale = btn.getAttribute('data-locale');
      if (!locale) return;
      document.cookie = `zav_lang=${locale};path=/;max-age=31536000;samesite=lax`;
      location.reload();
    });
  });

  const setOpen = (open) => {
    if (!toggle || !mobileNav) return;
    toggle.setAttribute('aria-expanded', String(open));
    mobileNav.hidden = !open;
    document.body.classList.toggle('nav-open', open);
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') !== 'true';
    setOpen(open);
  });

  mobileNav?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });

  const onScroll = () => {
    const max = document.documentElement.scrollHeight - innerHeight;
    const p = max > 0 ? scrollY / max : 0;
    if (progress) progress.style.transform = `scaleX(${Math.min(Math.max(p, 0), 1)})`;
    header?.classList.toggle('is-scrolled', scrollY > 12);
  };

  const sections = ['services', 'work', 'quote']
    .map((id) => document.getElementById(id))
    .filter(Boolean);

  const syncActive = () => {
    let active = '';
    const y = scrollY + 120;
    for (const section of sections) {
      if (!section) continue;
      if (section.offsetTop <= y) active = section.id;
    }
    navLinks.forEach((link) => {
      link.classList.toggle('is-active', link.getAttribute('data-nav') === active);
    });
  };

  let scrollRaf = 0;
  const onScrollFrame = () => {
    scrollRaf = 0;
    onScroll();
    syncActive();
  };

  addEventListener('scroll', () => {
    if (!scrollRaf) scrollRaf = requestAnimationFrame(onScrollFrame);
  }, { passive: true });

  onScroll();
  syncActive();
</script>
