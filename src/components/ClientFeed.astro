---
import type { Messages } from '../i18n/messages';
import type { ClientWork } from '../lib/store';

interface Props {
  m: Messages;
  clients: ClientWork[];
}

const { m, clients } = Astro.props;

const starPath =
  'M12 2.4l2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 16.3 6.6 19.2l1-6.1L3.2 8.8l6.1-.9L12 2.4z';
---

<section id="work" class="section-block px-4 py-14 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-accent text-lg text-mustard-deep sm:text-xl">{m.navWork}</p>
        <h2 class="font-display mt-2 text-3xl tracking-tight text-ink sm:text-4xl">{m.feedTitle}</h2>
        <p class="mt-2 text-sm text-muted sm:text-base">{m.feedSub}</p>
      </div>
    </div>

    {clients.length === 0 ? (
      <p class="reveal text-center text-muted">{m.feedEmpty}</p>
    ) : (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" translate="no">
        {clients.map((client, i) => (
          <article
            class:list={['feed-card reveal', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}
            lang="en"
            translate="no"
          >
            <div class="mb-3 flex items-center justify-between gap-3">
              <div>
                <p class="font-semibold text-ink">{client.name}</p>
                <p class="text-xs text-muted">{client.city}</p>
              </div>
              <span class="rounded-full bg-mustard/20 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-mustard-deep">
                {client.service}
              </span>
            </div>
            <p class="text-sm leading-relaxed text-ink-soft">“{client.blurb}”</p>
            <div class="mt-4 flex items-center justify-between text-xs text-muted">
              <span class="star-row" aria-label={`${client.rating} stars`}>
                {Array.from({ length: Math.max(0, Math.min(5, client.rating || 0)) }).map((_, si) => (
                  <svg
                    class="star-icon"
                    style={`--i:${si}`}
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    aria-hidden="true"
                  >
                    <path d={starPath} />
                  </svg>
                ))}
              </span>
              <time datetime={client.date}>{client.date}</time>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .star-row {
    display: inline-flex;
    align-items: center;
    gap: 0.18rem;
  }

  .star-icon {
    fill: #f5c84b;
    color: #f5c84b;
    filter: drop-shadow(0 0 2px rgba(245, 200, 75, 0.45));
    transform-origin: center;
    animation: star-twinkle 2.4s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.18s);
  }

  .feed-card:hover .star-icon {
    animation-duration: 1.4s;
    filter: drop-shadow(0 0 5px rgba(245, 200, 75, 0.7));
  }

  @keyframes star-twinkle {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.88;
    }
    40% {
      transform: scale(1.12);
      opacity: 1;
    }
    70% {
      transform: scale(0.96);
      opacity: 0.95;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .star-icon {
      animation: none;
    }
  }
</style>
