---
import type { Messages } from '../i18n/messages';
import type { ClientWork } from '../lib/store';

interface Props {
  m: Messages;
  clients: ClientWork[];
}

const { m, clients } = Astro.props;

const starPath =
  'M12 2.4l2.7 5.5 6.1.9-4.4 4.3 1 6.1L12 16.3 6.6 19.2l1-6.1L3.2 8.8l6.1-.9L12 2.4z';

const AVATAR_COLORS = ['#6b4538', '#c67a62', '#8a5a3c', '#4a2f28', '#b8845a', '#7a4e3a'];

function initials(name: string) {
  const parts = name.replace(/[^a-zA-ZÀ-ÿ&\s.]/g, ' ').trim().split(/\s+/).filter(Boolean);
  if (parts.length === 0) return 'Z';
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  const first = parts[0][0] || 'Z';
  const last = parts[parts.length - 1][0] || '';
  return `${first}${last}`.toUpperCase();
}

function avatarColor(name: string) {
  let hash = 0;
  for (let i = 0; i < name.length; i++) hash = (hash + name.charCodeAt(i) * (i + 1)) % 997;
  return AVATAR_COLORS[hash % AVATAR_COLORS.length];
}

function formatReviewDate(iso: string) {
  const d = new Date(`${iso}T12:00:00`);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<section id="work" class="section-block px-4 py-14 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-accent text-lg text-mustard-deep sm:text-xl">{m.navWork}</p>
        <h2 class="font-display mt-2 text-3xl tracking-tight text-ink sm:text-4xl">{m.feedTitle}</h2>
        <p class="mt-2 text-sm text-muted sm:text-base">{m.feedSub}</p>
      </div>
    </div>

    {clients.length === 0 ? (
      <p class="reveal text-center text-muted">{m.feedEmpty}</p>
    ) : (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" translate="no">
        {clients.map((client, i) => (
          <article
            class:list={['review-profile reveal', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}
            lang="en"
            translate="no"
          >
            <header class="review-profile__head">
              <div
                class="review-profile__avatar"
                style={`background:${avatarColor(client.name)}`}
                aria-hidden="true"
              >
                {initials(client.name)}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0">
                    <p class="review-profile__name">{client.name}</p>
                    <p class="review-profile__meta">{client.city}</p>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center gap-2">
                  <span class="star-row" aria-label={`${client.rating} stars`}>
                    {Array.from({ length: Math.max(0, Math.min(5, client.rating || 0)) }).map((_, si) => (
                      <svg
                        class="star-icon"
                        style={`--i:${si}`}
                        viewBox="0 0 24 24"
                        width="15"
                        height="15"
                        aria-hidden="true"
                      >
                        <path d={starPath} />
                      </svg>
                    ))}
                  </span>
                  <span class="review-profile__service">{client.service}</span>
                </div>
              </div>
            </header>

            <p class="review-profile__body">“{client.blurb}”</p>

            <footer class="review-profile__foot">
              <time datetime={client.date}>{formatReviewDate(client.date)}</time>
              <span class="review-profile__src">Local customer</span>
            </footer>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .review-profile {
    border-radius: 1.1rem;
    border: 1px solid rgba(42, 33, 30, 0.07);
    background: #fff;
    padding: 1.1rem 1.15rem 1rem;
    box-shadow: 0 8px 24px rgba(107, 69, 56, 0.05);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .review-profile:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(107, 69, 56, 0.1);
  }

  .review-profile__head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .review-profile__avatar {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.2);
  }

  .review-profile__name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-profile__meta {
    margin-top: 0.12rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .review-profile__service {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mustard-deep);
    background: rgba(245, 200, 75, 0.16);
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
  }

  .review-profile__body {
    margin-top: 0.85rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .review-profile__foot {
    margin-top: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .review-profile__src {
    opacity: 0.8;
  }

  .star-row {
    display: inline-flex;
    align-items: center;
    gap: 0.12rem;
  }

  .star-icon {
    fill: #fbbc04;
    color: #fbbc04;
    filter: drop-shadow(0 0 2px rgba(251, 188, 4, 0.4));
    transform-origin: center;
    animation: star-twinkle 2.4s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.18s);
  }

  .review-profile:hover .star-icon {
    animation-duration: 1.35s;
    filter: drop-shadow(0 0 5px rgba(251, 188, 4, 0.65));
  }

  @keyframes star-twinkle {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    45% {
      transform: scale(1.14);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .star-icon {
      animation: none;
    }
    .review-profile:hover {
      transform: none;
    }
  }
</style>
