---
import type { Messages } from '../i18n/messages';
import type { ClientWork } from '../lib/store';

interface Props {
  m: Messages;
  clients: ClientWork[];
}

const { m, clients } = Astro.props;

const starPath =
  'M12 2l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 16.5 6.2 19.9l1.1-6.5L2.6 8.8l6.5-.9L12 2z';

const AVATAR_COLORS = ['#6b4538', '#c67a62', '#8a5a3c', '#4a2f28', '#b8845a', '#7a4e3a'];

const serviceIcons = {
  home: 'M4 10.5 12 3.5l8 7V21a.8.8 0 0 1-.8.8h-4.7v-6.2H9.5v6.2H4.8A.8.8 0 0 1 4 21v-10.5z',
  deep: 'M12 2.2l1.2 3.7 3.9.2-3.1 2.4 1 3.7L12 10.2 8.9 12.1l1-3.7L6.9 6.1l3.9-.2L12 2.2zm-6.8 9.4.9 2.7 2.9.1-2.3 1.8.7 2.8L5.2 17.3 2.7 19l.7-2.8-2.3-1.8 2.9-.1.9-2.7zm13.6 0 .9 2.7 2.9.1-2.3 1.8.7 2.8-2.5-1.7-2.5 1.7.7-2.8-2.3-1.8 2.9-.1.9-2.7zM5.5 20.2h13v1.3H5.5z',
  move: 'M3.5 8.2h10.2a1.6 1.6 0 0 1 1.6 1.6V19H3.5V8.2zm11.8 1.7h2.6l1.9 2.4V19h-4.5V9.9zM6.2 5h5.5v3.2H6.2V5zm1.8 6.2h3v1.5h-3V11.2z',
  office:
    'M3.8 21V4.8A.8.8 0 0 1 4.6 4h8.2a.8.8 0 0 1 .8.8V21H3.8zm11.2 0V9.2h4.4a.8.8 0 0 1 .8.8V21h-5.2zM6.2 7.2h2v2h-2v-2zm0 3.6h2v2h-2v-2zm0 3.6h2v2h-2v-2zm3.6-7.2h2v2h-2v-2zm0 3.6h2v2h-2v-2z',
} as const;

const serviceOptions = [
  { label: m.services.home, icon: serviceIcons.home },
  { label: m.services.deep, icon: serviceIcons.deep },
  { label: m.services.move, icon: serviceIcons.move },
  { label: m.servicesOffice, icon: serviceIcons.office },
];

function initials(name: string) {
  const parts = name.replace(/[^a-zA-ZÀ-ÿ&\s.]/g, ' ').trim().split(/\s+/).filter(Boolean);
  if (parts.length === 0) return 'Z';
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  const first = parts[0][0] || 'Z';
  const last = parts[parts.length - 1][0] || '';
  return `${first}${last}`.toUpperCase();
}

function avatarColor(name: string) {
  let hash = 0;
  for (let i = 0; i < name.length; i++) hash = (hash + name.charCodeAt(i) * (i + 1)) % 997;
  return AVATAR_COLORS[hash % AVATAR_COLORS.length];
}

function formatReviewDate(iso: string) {
  const d = new Date(`${iso}T12:00:00`);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<section id="work" class="section-block px-4 py-14 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-accent text-lg text-mustard-deep sm:text-xl">{m.navWork}</p>
        <h2 class="font-display mt-2 text-3xl tracking-tight text-ink sm:text-4xl">{m.feedTitle}</h2>
        <p class="mt-2 text-sm text-muted sm:text-base">{m.feedSub}</p>
      </div>
      <a href="#leave-review" class="btn-accent !px-4 !py-2.5 text-xs">{m.reviewCta}</a>
    </div>

    {clients.length === 0 ? (
      <p class="reveal text-center text-muted">{m.feedEmpty}</p>
    ) : (
      <div id="reviews-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" translate="no">
        {clients.map((client, i) => (
          <article
            class:list={['review-profile reveal', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}
            lang="en"
            translate="no"
          >
            <header class="review-profile__head">
              <div
                class="review-profile__avatar"
                style={`background:${avatarColor(client.name)}`}
                aria-hidden="true"
              >
                {initials(client.name)}
              </div>
              <div class="min-w-0 flex-1">
                <div class="min-w-0">
                  <p class="review-profile__name">{client.name}</p>
                  <p class="review-profile__meta">{client.city}</p>
                </div>
                <div class="mt-1.5 flex items-center gap-2">
                  <span class="star-row" aria-label={`${client.rating} stars`}>
                    {Array.from({ length: Math.max(0, Math.min(5, client.rating || 0)) }).map((_, si) => (
                      <svg
                        class="star-icon"
                        style={`--i:${si}`}
                        viewBox="0 0 24 24"
                        width="15"
                        height="15"
                        aria-hidden="true"
                      >
                        <path d={starPath} />
                      </svg>
                    ))}
                  </span>
                  <span class="review-profile__service">{client.service}</span>
                </div>
              </div>
            </header>

            <p class="review-profile__body">“{client.blurb}”</p>

            <footer class="review-profile__foot">
              <time datetime={client.date}>{formatReviewDate(client.date)}</time>
              <span class="review-profile__src">Local customer</span>
            </footer>
          </article>
        ))}
      </div>
    )}

    <div id="leave-review" class="review-form-wrap reveal mt-10 scroll-mt-28">
      <h3 class="font-display text-2xl tracking-tight text-ink">{m.reviewTitle}</h3>
      <form id="review-form" class="review-form mt-5 grid gap-3 sm:grid-cols-2">
        <label class="review-field">
          <span>{m.reviewName}</span>
          <input class="field" name="name" type="text" required maxlength="80" autocomplete="name" />
        </label>
        <label class="review-field">
          <span>{m.reviewCity}</span>
          <input class="field" name="city" type="text" required maxlength="80" placeholder="Orlando, FL" />
        </label>

        <div class="review-field sm:col-span-2">
          <span>{m.reviewService}</span>
          <input type="hidden" name="service" id="review-service" value={serviceOptions[0].label} required />
          <div class="service-picks" role="group" aria-label={m.reviewService}>
            {serviceOptions.map((s, i) => (
              <button
                type="button"
                class:list={['service-pick', i === 0 && 'is-active']}
                data-service={s.label}
              >
                <svg class="service-pick__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d={s.icon} />
                </svg>
                <span>{s.label}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="review-field sm:col-span-2">
          <span>{m.reviewRating}</span>
          <input type="hidden" name="rating" id="review-rating" value="5" required />
          <div class="rating-picks" role="radiogroup" aria-label={m.reviewRating}>
            <svg class="rating-defs" width="0" height="0" aria-hidden="true">
              <defs>
                <linearGradient id="rating-star-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#ffe566" />
                  <stop offset="50%" stop-color="#fbbc04" />
                  <stop offset="100%" stop-color="#f09a1a" />
                </linearGradient>
              </defs>
            </svg>
            {[1, 2, 3, 4, 5].map((n) => (
              <button
                type="button"
                class:list={['rating-star', 'is-on', n >= 4 && 'is-big']}
                data-rating={n}
                style={`--i:${n - 1}`}
                aria-label={`${n} stars`}
                aria-checked={n === 5 ? 'true' : 'false'}
                role="radio"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path class="rating-star__shape" d={starPath} />
                </svg>
              </button>
            ))}
          </div>
        </div>

        <label class="review-field sm:col-span-2">
          <span>{m.reviewBody}</span>
          <textarea class="field min-h-[110px]" name="blurb" required maxlength="500" rows="4"></textarea>
        </label>
        <div class="sm:col-span-2 flex flex-wrap items-center gap-3">
          <button type="submit" class="btn-accent" data-review-submit>
            {m.reviewSubmit}
          </button>
          <p class="text-sm text-muted" data-review-msg hidden></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ labels: { sending: m.reviewSending, submit: m.reviewSubmit, success: m.reviewSuccess, error: m.reviewError }, starPath, defaultService: serviceOptions[0].label }}>
  const form = document.getElementById('review-form');
  const btn = form?.querySelector('[data-review-submit]');
  const msg = document.querySelector('[data-review-msg]');
  const grid = document.getElementById('reviews-grid');
  const ratingInput = document.getElementById('review-rating');
  const serviceInput = document.getElementById('review-service');
  const starBtns = [...(form?.querySelectorAll('.rating-star') || [])];
  const serviceBtns = [...(form?.querySelectorAll('.service-pick') || [])];

  const colors = ['#6b4538', '#c67a62', '#8a5a3c', '#4a2f28', '#b8845a', '#7a4e3a'];

  function setRating(value) {
    const n = Math.max(1, Math.min(5, Number(value) || 5));
    if (ratingInput) ratingInput.value = String(n);
    starBtns.forEach((el) => {
      const v = Number(el.getAttribute('data-rating') || 0);
      const on = v <= n;
      el.classList.toggle('is-on', on);
      el.setAttribute('aria-checked', v === n ? 'true' : 'false');
      if (on) {
        el.classList.remove('is-pop');
        void el.offsetWidth;
        el.classList.add('is-pop');
      }
    });
  }

  function setService(value) {
    if (serviceInput) serviceInput.value = value;
    serviceBtns.forEach((el) => {
      el.classList.toggle('is-active', el.getAttribute('data-service') === value);
    });
  }

  starBtns.forEach((el) => {
    el.addEventListener('click', () => setRating(el.getAttribute('data-rating')));
    el.addEventListener('mouseenter', () => {
      const hover = Number(el.getAttribute('data-rating') || 0);
      starBtns.forEach((s) => {
        const v = Number(s.getAttribute('data-rating') || 0);
        s.classList.toggle('is-hover', v <= hover);
      });
    });
  });

  form?.querySelector('.rating-picks')?.addEventListener('mouseleave', () => {
    starBtns.forEach((s) => s.classList.remove('is-hover'));
  });

  serviceBtns.forEach((el) => {
    el.addEventListener('click', () => setService(el.getAttribute('data-service') || defaultService));
  });

  function initials(name) {
    const parts = String(name).trim().split(/\s+/).filter(Boolean);
    if (!parts.length) return 'Z';
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return `${parts[0][0] || 'Z'}${parts[parts.length - 1][0] || ''}`.toUpperCase();
  }

  function avatarColor(name) {
    let hash = 0;
    for (let i = 0; i < name.length; i++) hash = (hash + name.charCodeAt(i) * (i + 1)) % 997;
    return colors[hash % colors.length];
  }

  function formatDate(iso) {
    const d = new Date(`${iso}T12:00:00`);
    if (Number.isNaN(d.getTime())) return iso;
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function starsHtml(rating) {
    return Array.from({ length: rating })
      .map(
        (_, si) =>
          `<svg class="star-icon" style="--i:${si}" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path d="${starPath}"/></svg>`,
      )
      .join('');
  }

  function prependCard(review) {
    if (!grid) {
      location.reload();
      return;
    }
    const article = document.createElement('article');
    article.className = 'review-profile reveal is-in';
    article.lang = 'en';
    article.translate = false;
    article.innerHTML = `
      <header class="review-profile__head">
        <div class="review-profile__avatar" style="background:${avatarColor(review.name)}" aria-hidden="true">${initials(review.name)}</div>
        <div class="min-w-0 flex-1">
          <div class="min-w-0">
            <p class="review-profile__name"></p>
            <p class="review-profile__meta"></p>
          </div>
          <div class="mt-1.5 flex items-center gap-2">
            <span class="star-row">${starsHtml(review.rating || 5)}</span>
            <span class="review-profile__service"></span>
          </div>
        </div>
      </header>
      <p class="review-profile__body"></p>
      <footer class="review-profile__foot">
        <time datetime="${review.date}">${formatDate(review.date)}</time>
        <span class="review-profile__src">Local customer</span>
      </footer>`;
    article.querySelector('.review-profile__name').textContent = review.name;
    article.querySelector('.review-profile__meta').textContent = review.city;
    article.querySelector('.review-profile__service').textContent = review.service;
    article.querySelector('.review-profile__body').textContent = `“${review.blurb}”`;
    grid.prepend(article);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') || '').trim(),
      city: String(fd.get('city') || '').trim(),
      service: String(fd.get('service') || '').trim(),
      blurb: String(fd.get('blurb') || '').trim(),
      rating: Number(fd.get('rating') || 5),
    };

    if (btn) {
      btn.disabled = true;
      btn.textContent = labels.sending;
    }
    if (msg) {
      msg.hidden = false;
      msg.textContent = '';
      msg.classList.remove('is-ok', 'is-err');
    }

    try {
      const res = await fetch('/api/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || labels.error);
      prependCard(data.review);
      form.reset();
      setRating(5);
      setService(defaultService);
      if (msg) {
        msg.textContent = labels.success;
        msg.classList.add('is-ok');
      }
    } catch (err) {
      if (msg) {
        msg.textContent = err instanceof Error ? err.message : labels.error;
        msg.classList.add('is-err');
      }
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = labels.submit;
      }
    }
  });
</script>

<style>
  .review-form-wrap {
    border-radius: 1.25rem;
    border: 1px solid rgba(42, 33, 30, 0.08);
    background: rgba(255, 255, 255, 0.72);
    padding: 1.25rem 1.25rem 1.35rem;
  }

  .review-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .service-picks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .service-pick {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid rgba(42, 33, 30, 0.12);
    background: #fff;
    color: var(--color-ink);
    border-radius: 999px;
    padding: 0.55rem 0.95rem 0.55rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease, color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .service-pick__icon {
    width: 1.05rem;
    height: 1.05rem;
    flex-shrink: 0;
    fill: currentColor;
    opacity: 0.72;
  }

  .service-pick:hover {
    transform: translateY(-1px);
    border-color: rgba(198, 122, 98, 0.45);
  }

  .service-pick.is-active {
    background: linear-gradient(135deg, #f5c84b, #efa978);
    border-color: transparent;
    color: #2a211e;
    box-shadow: 0 8px 18px rgba(245, 200, 75, 0.28);
  }

  .service-pick.is-active .service-pick__icon {
    opacity: 1;
  }

  .rating-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .rating-picks {
    position: relative;
    display: flex;
    align-items: flex-end;
    gap: 0.15rem;
    padding: 0.45rem 0.1rem 0.2rem;
  }

  .rating-star {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0.2rem;
    cursor: pointer;
    line-height: 0;
  }

  .rating-star svg {
    width: 1.7rem;
    height: 1.7rem;
    overflow: visible;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), filter 0.25s ease;
    transform-origin: center bottom;
  }

  .rating-star__shape {
    fill: rgba(42, 33, 30, 0.12);
    stroke: rgba(42, 33, 30, 0.08);
    stroke-width: 0.6;
    transition: fill 0.2s ease, stroke 0.2s ease, filter 0.2s ease;
  }

  .rating-star.is-big svg {
    width: 2.4rem;
    height: 2.4rem;
  }

  .rating-star.is-on .rating-star__shape,
  .rating-star.is-hover .rating-star__shape {
    fill: url(#rating-star-grad);
    stroke: #e8a200;
    stroke-width: 0.35;
    filter: drop-shadow(0 0 5px rgba(251, 188, 4, 0.7));
  }

  .rating-star.is-on svg,
  .rating-star.is-hover svg {
    animation: star-live 2.2s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.14s);
  }

  .rating-star.is-pop svg {
    animation: rating-pop 0.48s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rating-star:hover svg {
    transform: scale(1.14) rotate(-4deg);
  }

  .rating-star.is-big:hover svg {
    transform: scale(1.22) rotate(-5deg);
  }

  @keyframes rating-pop {
    0% {
      transform: scale(0.72) rotate(-8deg);
    }
    55% {
      transform: scale(1.35) rotate(4deg);
    }
    100% {
      transform: scale(1) rotate(0);
    }
  }

  @keyframes star-live {
    0%,
    100% {
      transform: scale(1);
      filter: drop-shadow(0 0 3px rgba(251, 188, 4, 0.4));
    }
    50% {
      transform: scale(1.1);
      filter: drop-shadow(0 0 8px rgba(251, 188, 4, 0.85));
    }
  }

  .review-form [data-review-msg].is-ok {
    color: #1f7a4d;
  }

  .review-form [data-review-msg].is-err {
    color: #a33b2b;
  }

  .review-profile {
    border-radius: 1.1rem;
    border: 1px solid rgba(42, 33, 30, 0.07);
    background: #fff;
    padding: 1.1rem 1.15rem 1rem;
    box-shadow: 0 8px 24px rgba(107, 69, 56, 0.05);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .review-profile:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(107, 69, 56, 0.1);
  }

  .review-profile__head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .review-profile__avatar {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.2);
  }

  .review-profile__name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-profile__meta {
    margin-top: 0.12rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .review-profile__service {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mustard-deep);
    background: rgba(245, 200, 75, 0.16);
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
  }

  .review-profile__body {
    margin-top: 0.85rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .review-profile__foot {
    margin-top: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .review-profile__src {
    opacity: 0.8;
  }

  .star-row {
    display: inline-flex;
    align-items: center;
    gap: 0.12rem;
  }

  .star-icon {
    fill: #fbbc04;
    color: #fbbc04;
    filter: drop-shadow(0 0 2px rgba(251, 188, 4, 0.4));
    transform-origin: center;
    animation: star-twinkle 2.4s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.18s);
  }

  .review-profile:hover .star-icon {
    animation-duration: 1.35s;
    filter: drop-shadow(0 0 5px rgba(251, 188, 4, 0.65));
  }

  @keyframes star-twinkle {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    45% {
      transform: scale(1.14);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .star-icon,
    .rating-star.is-on svg,
    .rating-star.is-hover svg,
    .rating-star.is-pop svg {
      animation: none;
    }
    .review-profile:hover {
      transform: none;
    }
  }
</style>
