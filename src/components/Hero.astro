---
import type { Messages } from '../i18n/messages';
import { PHONE_DISPLAY, PHONE_E164, whatsappUrl } from '../lib/contact';
import BrandLogo from './BrandLogo.astro';

interface Props {
  m: Messages;
}

const { m } = Astro.props;
const wa = whatsappUrl(m.whatsappMsg);
---

<section class="hero-bleed relative overflow-hidden" id="top">
  <div class="hero-bleed__media" aria-hidden="true">
    <img
      src="/hero-bedroom.jpg"
      alt=""
      width="1600"
      height="1000"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-bleed__veil"></div>
  </div>

  <div class="relative mx-auto flex min-h-[78vh] max-w-6xl flex-col justify-end px-4 pb-14 pt-28 sm:px-6 sm:pb-20 sm:pt-32">
    <div class="reveal mb-6 max-w-2xl">
      <BrandLogo size="lg" priority class="hero-logo mb-6 max-w-[min(100%,280px)] brightness-0 invert" />
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-mustard-soft">{m.heroEyebrow}</p>
      <h1 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-cream sm:text-5xl lg:text-6xl">
        {m.heroTitle}
      </h1>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-cream/85 sm:text-lg">{m.heroSub}</p>
      <p class="mt-3 text-sm font-medium text-mustard">{m.areaLabel}</p>
    </div>

    <div class="reveal reveal-delay-1 mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <a href="#quote" class="magnet btn-accent">
        <span class="magnet__inner">{m.heroCta}</span>
      </a>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-wa border border-cream/25 bg-navy/70 backdrop-blur-sm">
        {m.whatsappCta}
      </a>
    </div>

    <a href={`tel:${PHONE_E164}`} class="reveal reveal-delay-2 mt-5 inline-flex items-center gap-2 text-sm text-cream/80">
      <span class="opacity-70">{m.heroPhone}</span>
      <span class="font-medium text-cream">{PHONE_DISPLAY}</span>
    </a>
  </div>
</section>

<style>
  .hero-bleed__media {
    position: absolute;
    inset: 0;
  }
  .hero-bleed__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-bleed__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(42, 33, 30, 0.35) 0%, rgba(42, 33, 30, 0.55) 45%, rgba(42, 33, 30, 0.82) 100%),
      linear-gradient(90deg, rgba(107, 69, 56, 0.35), transparent 55%);
  }
</style>
