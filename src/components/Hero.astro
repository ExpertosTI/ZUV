---
import type { Messages } from '../i18n/messages';
import { PHONE_DISPLAY, PHONE_E164, whatsappUrl } from '../lib/contact';

interface Props {
  m: Messages;
}

const { m } = Astro.props;
const wa = whatsappUrl(m.whatsappMsg);

const heroSlides = [
  { src: '/hero-bedroom.jpg', w: 932, h: 1400, pos: 'center 22%' },
  { src: '/service-home-v3.jpg', w: 480, h: 600, pos: 'center 40%' },
  { src: '/service-move.jpg', w: 480, h: 600, pos: 'center 30%' },
  { src: '/service-decor-v3.jpg', w: 480, h: 600, pos: 'center 45%' },
  { src: '/amenities-zav.jpg', w: 900, h: 798, pos: 'center 40%' },
] as const;
---

<section class="hero-bleed relative overflow-hidden" id="top">
  <div class="hero-bleed__media" aria-hidden="true" data-hero-slides>
    {heroSlides.map((slide, i) => (
      <img
        class:list={['hero-bleed__slide', i === 0 && 'is-active']}
        src={slide.src}
        alt=""
        width={slide.w}
        height={slide.h}
        loading={i === 0 ? 'eager' : 'lazy'}
        fetchpriority={i === 0 ? 'high' : 'low'}
        decoding="async"
        style={`--pos:${slide.pos}`}
        data-hero-slide
      />
    ))}
    <div class="hero-bleed__veil"></div>
  </div>

  <div class="hero-bleed__content relative mx-auto flex min-h-[88vh] max-w-6xl flex-col px-4 pt-24 pb-10 sm:min-h-[78vh] sm:justify-end sm:px-6 sm:pb-20 sm:pt-32">
    <div class="hero-copy reveal soft-rise mb-5 max-w-2xl">
      <p class="hero-eyebrow mb-3 text-[11px] font-semibold uppercase tracking-[0.2em] text-cream/80">
        {m.heroEyebrow}
      </p>
      <h1 class="font-display text-[2.15rem] leading-[1.08] tracking-tight text-cream sm:text-5xl lg:text-[3.5rem]">
        {m.heroTitle}
      </h1>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-cream/85 sm:text-lg">{m.heroSub}</p>
    </div>

    <div class="hero-actions reveal soft-rise reveal-delay-1 mt-5 flex flex-col gap-3 sm:mt-6 sm:flex-row sm:flex-wrap sm:items-center">
      <a href="#quote" class="magnet btn-accent">
        <span class="magnet__inner">{m.heroCta}</span>
      </a>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-wa border border-cream/25 bg-navy/55">
        {m.whatsappCta}
      </a>
    </div>

    <a
      href={`tel:${PHONE_E164}`}
      class="hero-phone reveal soft-rise reveal-delay-2 mt-5 inline-flex items-center gap-2 text-sm text-cream/80"
    >
      <span class="opacity-70">{m.heroPhone}</span>
      <span class="font-medium text-cream">{PHONE_DISPLAY}</span>
    </a>
  </div>
</section>

<script>
  const root = document.querySelector('[data-hero-slides]');
  const slides = [...(root?.querySelectorAll('[data-hero-slide]') || [])];
  if (slides.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    const INTERVAL_MS = 5500;
    window.setInterval(() => {
      slides[i]?.classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i]?.classList.add('is-active');
    }, INTERVAL_MS);
  }
</script>

<style>
  .hero-bleed__media {
    position: absolute;
    inset: 0;
  }
  .hero-bleed__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--pos, center 22%);
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 1.15s ease,
      transform 7s ease;
    will-change: opacity, transform;
  }
  .hero-bleed__slide.is-active {
    opacity: 1;
    transform: scale(1.12);
    z-index: 1;
  }
  .hero-bleed__veil {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(180deg, rgba(42, 33, 30, 0.22) 0%, rgba(42, 33, 30, 0.42) 40%, rgba(42, 33, 30, 0.78) 100%),
      linear-gradient(90deg, rgba(42, 33, 30, 0.5) 0%, rgba(42, 33, 30, 0.25) 52%, transparent 78%);
  }

  /* Mobile: centered block, mid-upper viewport */
  @media (max-width: 639px) {
    .hero-bleed__content {
      justify-content: flex-start;
      padding-top: clamp(7.5rem, 22vh, 11rem);
      align-items: center;
      text-align: center;
    }
    .hero-copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: 22rem;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-copy p,
    .hero-copy h1 {
      text-align: center;
    }
    .hero-actions {
      width: 100%;
      max-width: 20rem;
      align-items: stretch;
    }
    .hero-actions .btn-accent,
    .hero-actions .btn-wa {
      width: 100%;
      justify-content: center;
    }
    .hero-phone {
      justify-content: center;
    }
    .hero-bleed__slide {
      object-position: var(--pos, center 18%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bleed__slide {
      transition: none;
      transform: none;
    }
    .hero-bleed__slide.is-active {
      transform: none;
    }
  }
</style>
