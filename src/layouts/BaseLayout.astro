---
import '../styles/global.css';
import type { Locale } from '../i18n/messages';
import {
  SEO_COPY,
  SITE_NAME,
  SITE_URL,
  absoluteUrl,
  buildFaqJsonLd,
  buildLocalBusinessJsonLd,
  buildWebsiteJsonLd,
} from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  locale: Locale;
  canonicalPath?: string;
  noindex?: boolean;
  ogImage?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  locale,
  canonicalPath = '/',
  noindex = false,
  ogImage = '/hero-bedroom.jpg',
} = Astro.props;

const seo = SEO_COPY[locale] || SEO_COPY.en;
const title = Astro.props.title || seo.title;
const description = Astro.props.description || seo.description;
const canonical = absoluteUrl(canonicalPath);
const image = absoluteUrl(ogImage);
const logo = absoluteUrl('/logo.png');

const jsonLdBlocks = Astro.props.jsonLd || [
  buildLocalBusinessJsonLd(),
  buildWebsiteJsonLd(),
  buildFaqJsonLd(),
];
---

<!DOCTYPE html>
<html lang={locale} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content={SITE_NAME} />
    <meta name="theme-color" content="#f6f1eb" />
    <meta name="color-scheme" content="light" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=yes" />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow, noarchive" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={SITE_URL + '/'} />
    <link rel="alternate" hreflang="es" href={SITE_URL + '/'} />
    <link rel="alternate" hreflang="pt" href={SITE_URL + '/'} />
    <link rel="alternate" hreflang="x-default" href={SITE_URL + '/'} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <link rel="apple-touch-icon" href="/logo-mark.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="image"
      href={ogImage}
      fetchpriority="high"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Fredoka:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={seo.ogLocale} />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="es_US" />
    <meta property="og:locale:alternate" content="pt_BR" />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1600" />
    <meta property="og:image:height" content="1600" />
    <meta property="og:image:alt" content={`${SITE_NAME} — house cleaning in Orlando, FL`} />
    <meta property="og:logo" content={logo} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={`${SITE_NAME} — house cleaning in Orlando, FL`} />

    <!-- Geo / local -->
    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Orlando, FL" />
    <meta name="geo.position" content="28.5383;-81.3792" />
    <meta name="ICBM" content="28.5383, -81.3792" />
    <meta name="coverage" content="Orlando, Florida" />
    <meta name="distribution" content="local" />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="text-ink antialiased">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
    <div id="life-layer" class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true"></div>
    <div class="relative z-10">
      <slot />
    </div>

    <script>
      import { initInteract } from '../scripts/interact.js';
      import { initAdminLoader } from '../scripts/admin-loader.js';
      import { trackPageVisit } from '../scripts/visit-tracker.js';

      initInteract();
      initAdminLoader();
      trackPageVisit();

      const startFloatingLife = () => {
        const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const touch = matchMedia('(hover: none), (pointer: coarse)').matches;
        const narrow = matchMedia('(max-width: 900px)').matches;
        if (reduce || touch || narrow) return;
        import('../scripts/floating-life.js').then(({ initFloatingLife }) => initFloatingLife());
      };

      if ('requestIdleCallback' in window) {
        requestIdleCallback(startFloatingLife, { timeout: 4000 });
      } else {
        setTimeout(startFloatingLife, 2000);
      }
    </script>
  </body>
</html>
